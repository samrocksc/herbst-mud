# HerbSt Server - REST API Environment
# Copy this file to .env and fill in your values

# Database connection (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_USER=herbst
DB_PASSWORD=your_secure_password_here
DB_NAME=herbst_mud

# Server
SERVER_PORT=8080
SERVER_HOST=0.0.0.0

# JWT Authentication
JWT_SECRET=your_secure_jwt_secret_here_min_32_chars
