# HerbSt Server - REST API Environment
# Copy this file to .env and fill in your values

# ============================================================
# DATABASE CONNECTION
# ============================================================
# Option 1: DATABASE_URL (recommended for Neon DB and managed Postgres)
# This single variable contains all connection info
# Example from Neon: postgres://user:pass@host-pooler.neon.tech/dbname?sslmode=require
DATABASE_URL=

# Option 2: Individual variables (fallback if DATABASE_URL not set)
# For local development without SSL:
DB_HOST=localhost
DB_PORT=5432
DB_USER=herbst
DB_PASSWORD=your_secure_password_here
DB_NAME=herbst_mud
# SSL mode: 'require' for Neon/production, 'disable' only for local dev without SSL
DB_SSL_MODE=require

# ============================================================
# RATE LIMITING (DoS/Brute Force Protection)
# ============================================================
# Requests per time window (default: 100 requests per 60 seconds)
RATE_LIMIT=100
RATE_WINDOW=60

# ============================================================
# CORS CONFIGURATION
# ============================================================
# Comma-separated list of allowed origins (for browser security)
# Local dev: http://localhost:3000,http://localhost:5173
# Production: https://your-domain.com
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ============================================================
# SERVER
# ============================================================
SERVER_PORT=8080
SERVER_HOST=0.0.0.0

# ============================================================
# JWT AUTHENTICATION
# ============================================================
# Generate with: openssl rand -base64 32
JWT_SECRET=your_secure_jwt_secret_here_min_32_chars
