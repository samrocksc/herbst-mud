# HerbSt MUD - SSH Client Environment
# Copy this file to .env and fill in your values

# Database connection (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_USER=herbst
DB_PASSWORD=your_secure_password_here
DB_NAME=herbst_mud

# REST API server (web server)
API_BASE_URL=http://localhost:8080

# SSH Server
SSH_PORT=4444
SSH_HOST_KEY_PATH=.ssh/term_info_ed25519
