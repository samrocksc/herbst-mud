# ── Database ──
DB_HOST=postgres
DB_PORT=5432
DB_USER=herbst
DB_PASSWORD=CHANGE_ME_NOW
DB_NAME=herbst_mud
DATABASE_URL=postgres://herbst:CHANGE_ME_NOW@postgres:5432/herbst_mud?sslmode=disable

# ── Auth ──
JWT_SECRET=CHANGE_ME_NOW

# ── CORS origins (comma-separated public domains) ──
# Example: https://game.yourdomain.com,https://admin.yourdomain.com
CORS_ORIGINS=http://localhost

# ── Cloudflare Tunnel ──
# Get token from: https://one.dash.cloudflare.com/ → Access → Tunnels
CF_TUNNEL_TOKEN=CHANGE_ME_NOW

# ── SSH→API Bridge (Docker Compose service name) ──
API_BASE_URL=http://web:8080

# ── Optional Admin Events Account ──
# ADMIN_EMAIL=admin@yourdomain.com
# ADMIN_PASSWORD=change-me-too
