# Database (Docker Compose defaults — change for production)
DB_HOST=postgres
DB_PORT=5432
DB_USER=herbst
DB_PASSWORD=herbst_password
DB_NAME=herbst_mud
DATABASE_URL=postgres://herbst:herbst_password@postgres:5432/herbst_mud?sslmode=disable

# Auth (change for production!)
JWT_SECRET=development-jwt-secret-change-in-production

# CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Cloudflare Tunnel (get from https://one.dash.cloudflare.com/)
CF_TUNNEL_TOKEN=your-cloudflare-tunnel-token-here